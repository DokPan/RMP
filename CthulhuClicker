data class Particle(
    var x: Float,
    var y: Float,
    var alpha: Float = 1f,
    var angle: Float = Random.nextFloat()*2* PI.toFloat(),
    val speed: Float = Random.nextFloat()*5+2,
    val letter: String = ('A'..'Z').random().toString()

){
    private val speedX = cos(angle) * speed
    private val speedY = sin(angle) *speed
    var lifetime: Float = 1f

    fun update(): Boolean{
        x += speedX
        y += speedY
        alpha -= 0.02f
        lifetime -= 0.02f
        return lifetime > 0
    }
}

@Composable
fun ParticleAnimation(particles: MutableList<Particle>){
    var invalidate by remember { mutableStateOf(false) }
    LaunchedEffect(Unit) { 
        while (true){
            delay(16L)
            particles.removeAll{
                it.update()
                it.lifetime <= 0
            }
            invalidate = !invalidate
        }

    }
    
    val context = LocalContext.current
    Canvas(Modifier.fillMaxSize()){
        invalidate.let{

        for (part in particles){
            drawIntoCanvas{ canvas ->
                val paint = Paint().apply{
                    color = Color.argb(part.alpha,
                        0.38f,0.96f,0.86f)
                    textSize = 80f
                    typeface = ResourcesCompat.getFont(context,R.font.daedra)
                    setShadowLayer(10f,5f,5f, Color.BLACK)
                }

                canvas.nativeCanvas.drawText(
                    part.letter,
                    part.x, part.y,
                    paint
                )

            }
        }
        }
    }
}

